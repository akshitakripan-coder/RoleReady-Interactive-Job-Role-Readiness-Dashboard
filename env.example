# ─────────────────────────────────────────────
# env.example — copy this file to .env and fill in your values
# NEVER commit your actual .env file to the repository
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development                  # development | production
APP_PORT=8000
APP_SECRET_KEY=replace_with_strong_random_secret

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# For MongoDB: MONGO_URI=mongodb://localhost:27017/dbname

# ── Frontend ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# VITE_API_URL=http://localhost:8000   # if using Vite

# ── AI / LLM APIs ────────────────────────────
# Include only what your project uses — delete the rest
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Cloud / Storage ──────────────────────────
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=your_bucket_name

CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── Auth ─────────────────────────────────────
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRY=7d

GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ── Email ─────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password

# ── Add your project-specific variables below ─
